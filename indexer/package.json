{
  "name": "fundable-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.8",
  "engines": {
    "bun": "1.3.8",
    "node": "22.x"
  },
  "workspaces": ["common", "streams", "distributions"],
  "scripts": {
    "build": "turbo run build",
    "codegen": "turbo run codegen",
    "dev": "turbo run dev --parallel",
    "format": "biome format --write .",
    "lint": "biome check .",
    "preinstall": "bun ./scripts/enforce-bun-install.ts",
    "start": "bun run dev",
    "test": "turbo run test",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "2.9.18",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  }
}
